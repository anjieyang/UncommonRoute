# UncommonRoute environment variables
# Copy to .env and fill in your values:  cp .env.example .env

# Commonstack API key (default upstream) — get one at https://commonstack.ai
COMMONSTACK_API_KEY=

# Optional: upstream API (default: https://api.commonstack.ai/v1)
# UNCOMMON_ROUTE_UPSTREAM=https://api.commonstack.ai/v1

# Optional: proxy port (default: 8403)
# UNCOMMON_ROUTE_PORT=8403

# Optional: for the comparison API (api.py) — Claude-as-judge
# ANTHROPIC_API_KEY=
